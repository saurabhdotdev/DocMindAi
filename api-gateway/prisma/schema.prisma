datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

enum UserRole {
  USER
  ADMIN
}

enum JobType {
  CONVERSION
  OCR
  SUMMARIZATION
  TRANSLATION
  ENTITY_EXTRACTION
  CLASSIFICATION
  TABLE_EXTRACTION
  AUDIO_AI
  VIDEO_AI
  IMAGE_AI
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ChatRole {
  USER
  ASSISTANT
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  passwordHash      String?            // Nullable for OAuth-only users
  firstName         String?
  lastName          String?
  role              UserRole           @default(USER)
  isEmailVerified   Boolean            @default(false)
  googleId          String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  sessions          Session[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  verificationTokens VerificationToken[]
  documents         Document[]
  chatSessions      ChatSession[]
  notifications     Notification[]
  subscription      Subscription?
  folders           Folder[]
  workflows         Workflow[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model Document {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  name        String
  type        String    // PDF, DOCX, PPTX, XLSX, etc.
  size        Int       // In bytes
  storageKey  String    // S3 object key
  mimeType    String
  status      JobStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobLogs        JobLog[]
  chatSessions   ChatSession[]
  ocrResult      OCRResult?
  classification DocumentClassification?
  resumeAnalysis ResumeAnalysis?
  extractedTables ExtractedTable[]
  entities       Entity[]
  folderId       String?                 @db.Uuid
  folder         Folder?                 @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@map("documents")
}

model JobLog {
  id         String    @id @default(uuid()) @db.Uuid
  documentId String    @db.Uuid
  jobType    JobType
  status     JobStatus @default(PENDING)
  resultKey  String?   // S3 key to output files (e.g. converted file, table CSV)
  error      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("job_logs")
}

model ChatSession {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @db.Uuid
  documentId String        @db.Uuid
  title      String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @db.Uuid
  role      ChatRole
  content   String   @db.Text
  citations Json?    // JSON array of references (page numbers, score, matched chunks)
  createdAt DateTime @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model OCRResult {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @unique @db.Uuid
  text       String   @db.Text
  layout     Json     // Detailed bounding boxes, segments, pages metadata
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("ocr_results")
}

model ExtractedTable {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @db.Uuid
  pageNumber Int
  tableData  Json     // Matrix or dictionary representation of the table
  csvUrl     String?  // Storage location for CSV export
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("extracted_tables")
}

model Entity {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @db.Uuid
  name       String
  category   String   // PERSON, ORG, DATE, MONEY, GST_NO, etc.
  value      String
  startChar  Int
  endChar    Int
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("entities")
}

model ResumeAnalysis {
  id          String   @id @default(uuid()) @db.Uuid
  documentId  String   @unique @db.Uuid
  skills      Json     // Array of skills
  education   Json     // Array of education objects
  experience  Json     // Array of work experience objects
  projects    Json     // Array of projects
  atsScore    Int
  suggestions Json     // Array of improvement suggestions
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("resume_analyses")
}

model DocumentClassification {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @unique @db.Uuid
  label      String   // Invoice, Receipt, Resume, Passport, etc.
  confidence Float
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_classifications")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String   // CONVERSION_COMPLETE, OCR_FINISHED, etc.
  title     String
  message   String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Subscription {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @unique @db.Uuid
  plan                 SubscriptionPlan @default(FREE)
  status               String           // active, trialing, past_due, canceled
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Folder {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @db.Uuid
  name       String
  sharedWith Json       @default("[]") // Array of user emails who have read access
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents  Document[]

  @@map("folders")
}

model Workflow {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  name       String
  trigger    String   @default("DOCUMENT_PROCESSED")
  conditions Json     // Conditions configuration: { field: string, operator: string, value: string }
  actions    Json     // Actions configuration: { action: string, folderId?: string }
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workflows")
}
